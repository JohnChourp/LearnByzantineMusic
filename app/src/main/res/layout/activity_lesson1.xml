<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:adjustViewBounds="true"
    android:orientation="vertical"
    tools:context=".Lesson1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/Lesson_1_id"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center|center_horizontal|center_vertical"
            android:text="@string/Lesson_1"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/PhthongNames_id"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center|center_horizontal|center_vertical"
            android:text="@string/PhthongNames"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/Phthongs_id"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center|center_horizontal|center_vertical"
            android:text="@string/Phthongs"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/Phthongs_definition_id"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/Phthongs_definition"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/phthongs_staircase_id"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="@string/todo"
                app:srcCompat="@drawable/phthongs_staircase"
                tools:ignore="ContentDescription" />
        </LinearLayout>
        <TextView
            android:id="@+id/Testimonials_id"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center|center_horizontal|center_vertical"
            android:text="@string/Testimonials"
            android:textSize="20sp"
            android:textStyle="bold" />

