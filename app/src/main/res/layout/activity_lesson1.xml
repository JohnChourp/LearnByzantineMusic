<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".Lesson1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/Lesson_1_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|center_horizontal|center_vertical"
            android:text="@string/Lesson_1"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/PhthongNames_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|center_horizontal|center_vertical"
            android:text="@string/PhthongNames"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/Phthongs_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|center_horizontal|center_vertical"
            android:text="@string/Phthongs"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/Phthongs_definition_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/Phthongs_definition"
            android:textSize="20sp" />

        <ImageView
            android:id="@+id/phthongs_staircase_id"
            android:layout_width="333.33dp"
            android:layout_height="166.67dp"
            android:layout_gravity="center"
            app:srcCompat="@drawable/phthongs_staircase"
            android:contentDescription="TODO"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/Testimonials_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|center_horizontal|center_vertical"
            android:text="@string/Testimonials"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/Testimonials_definition_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/Testimonials_definition"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/Testimonials_examples_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|center_horizontal|center_vertical"
            android:text="@string/Testimonials_examples"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/matching_phthongs_with_testimonials_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/matching_phthongs_with_testimonials"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/Phthongs_with_more_spaces_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|center_horizontal|center_vertical"
            android:text="@string/Phthongs_with_more_spaces"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:srcCompat="@drawable/testimonial_n" />

            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:srcCompat="@drawable/testimonial_p" />

            <ImageView
                android:id="@+id/imageView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:srcCompat="@drawable/testimonial_b" />

            <ImageView
                android:id="@+id/imageView6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:srcCompat="@drawable/testimonial_g" />

            <ImageView
                android:id="@+id/imageView7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:srcCompat="@drawable/testimonial_d" />

            <ImageView
                android:id="@+id/imageView8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:srcCompat="@drawable/testimonial_k" />

            <ImageView
                android:id="@+id/imageView9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:srcCompat="@drawable/testimonial_z" />

            <ImageView
                android:id="@+id/imageView10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:srcCompat="@drawable/testimonial_n1" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>