<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="411dp"
    android:layout_height="914dp"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/LearnBuzantineMusicWithLessons_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|center_horizontal|center_vertical"
            android:text="@string/LearnBuzantineMusicWithLessons"
            android:textSize="16sp"
            android:layout_gravity="center"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/Lesson_1_id"
                style="?android:attr/buttonBarStyle"
                android:layout_width="125dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginLeft="9dp"
                android:text="@string/Lesson_1"
                android:textSize="12sp" />

            <Button
                android:id="@+id/Lesson_2_id"
                style="?android:attr/buttonBarStyle"
                android:layout_width="125dp"
                android:layout_height="match_parent"
                android:layout_marginStart="9dp"
                android:layout_marginLeft="9dp"
                android:text="@string/Lesson_2"
                android:textSize="12sp" />

            <Button
                android:id="@+id/Lesson_3_id"
                style="?android:attr/buttonBarStyle"
                android:layout_width="125dp"
                android:layout_height="match_parent"
                android:layout_marginStart="9dp"
                android:layout_marginLeft="9dp"
                android:layout_marginEnd="9dp"
                android:layout_marginRight="9dp"
                android:text="@string/Lesson_3"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/Lesson_4_id"
                style="?android:attr/buttonBarStyle"
                android:layout_width="125dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_marginLeft="9dp"
                android:text="@string/Lesson_4"
                android:textSize="12sp" />

            <Button
                android:id="@+id/Lesson_5_id"
                style="?android:attr/buttonBarStyle"
                android:layout_width="125dp"
                android:layout_height="match_parent"
                android:layout_marginStart="9dp"
                android:layout_marginLeft="9dp"
                android:text="@string/Lesson_5"
                android:textSize="12sp" />

            <Button
                android:id="@+id/Lesson_6_id"
                style="?android:attr/buttonBarStyle"
                android:layout_width="125dp"
                android:layout_height="match_parent"
                android:layout_marginStart="9dp"
                android:layout_marginLeft="9dp"
                android:layout_marginEnd="9dp"
                android:layout_marginRight="9dp"
                android:text="@string/Lesson_6"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>